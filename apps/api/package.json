{
  "name": "@daily-sudoku/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:test": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "tsx ../../scripts/run-prisma.ts generate",
    "prisma:migrate:deploy": "tsx ../../scripts/run-prisma.ts migrate deploy",
    "prisma:migrate:dev": "tsx ../../scripts/run-prisma.ts migrate dev",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@daily-sudoku/contracts": "*",
    "@daily-sudoku/puzzles": "*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.6.0",
    "argon2": "^0.41.1",
    "fastify": "^5.2.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
