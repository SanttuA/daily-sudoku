{
  "name": "@daily-sudoku/puzzles",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --out-dir dist --watch",
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "generate": "tsx src/generate-catalog.ts",
    "import": "tsx src/import-catalog.ts"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
